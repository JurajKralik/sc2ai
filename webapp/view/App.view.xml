<mvc:View
  controllerName="sc2ai.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">
  <App>
    <pages>
      <Page title="SC2AI ARENA">
        <content>
          <VBox class="sapUiSmallMargin">
            <HBox justifyContent="SpaceBetween" alignItems="Center">
              <VBox>
                <Title text="Bot: {matches>/botName}"/>
              </VBox>
            </HBox>
            
            <HBox wrap="Wrap" class="sapUiSmallMarginTop">
              <ObjectStatus text="Wins: {matches>/summary/wins}" state="Success" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
              <ObjectStatus text="Losses: {matches>/summary/losses}" state="Error" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
              <ObjectStatus text="Ties: {matches>/summary/ties}" state="Warning" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
            </HBox>

            <HBox wrap="Wrap" class="sapUiSmallMarginTop">
              <ObjectStatus text="Win rate: {matches>/summary/winRate}" state="Information" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
            </HBox>

            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginTop sapUiTinyMarginBottom">
              <Text text="Loaded: {matches>/paging/loadedCount} / {matches>/paging/totalCount}"/>
            </HBox>

            <Table id="matchesTable" items="{matches>/matches}" busy="{matches>/loading}" growing="true" growingThreshold="20" growingScrollToLoad="true" updateFinished=".onUpdateFinished">
              <headerToolbar>
                <OverflowToolbar>
                  <Title text="Matches history" level="H3"/>
                </OverflowToolbar>
              </headerToolbar>
              <columns>
                <Column><Text text="Match"/></Column>
                <Column><Text text="Opponent"/></Column>
                <Column><Text text="Race"/></Column>
                <Column><Text text="Outcome"/></Column>
                <Column><Text text="Result type"/></Column>
                <Column><Text text="Started"/></Column>
                <Column hAlign="Center"><Text text="Log"/></Column>
                <Column hAlign="Center"><Text text="Replay"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{matches>id}"/>
                    <Text text="{matches>opponent}"/>
                    <ObjectStatus text="{matches>opponentRaceDisplay}" state="{matches>opponentRaceState}"/>
                    <ObjectStatus text="{matches>outcome}" state="{matches>state}"/>
                    <ObjectStatus text="{matches>resultTypeDisplay}" state="{matches>resultTypeState}"/>
                    <Text text="{matches>startedDisplay}"/>
                    <Button text="Log" enabled="{= !!${matches>log} }" press=".onOpenLink">
                      <customData>
                        <core:CustomData key="url" value="{matches>log}"/>
                      </customData>
                    </Button>
                    <Button text="Replay" enabled="{= !!${matches>replay} }" press=".onOpenLink">
                      <customData>
                        <core:CustomData key="url" value="{matches>replay}"/>
                      </customData>
                    </Button>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </VBox>
        </content>
      </Page>
    </pages>
  </App>
</mvc:View>
