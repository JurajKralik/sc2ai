<mvc:View
  controllerName="sc2ai.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  displayBlock="true">
  <App>
    <pages>
      <Page title="SC2AI ARENA">
        <content>
          <VBox class="sapUiSmallMargin">
            <HBox justifyContent="SpaceBetween" alignItems="Center">
              <HBox alignItems="Center" renderType="Bare">
                <Image src="{matches>/botRaceIcon}" width="2.2rem" height="2.2rem" decorative="false" densityAware="false" class="sapUiTinyMarginEnd"/>
                <VBox>
                  <Title text="Bot: {matches>/botName}"/>
                  <Text text="Updated: {matches>/botUpdatedDisplay}"/>
                </VBox>
              </HBox>
              <VBox alignItems="End">
                <ObjectStatus text="Elo: {matches>/ranking/elo}" state="Information"/>
                <Text text="Division {matches>/ranking/division} | Rank {matches>/ranking/overallRank}/{matches>/ranking/overallTotal}"/>
                <Text text="Division rank {matches>/ranking/divisionRank}/{matches>/ranking/divisionTotal}"/>
              </VBox>
            </HBox>
            
            <HBox wrap="Wrap" class="sapUiSmallMarginTop">
              <ObjectStatus text="Wins: {matches>/summary/wins}" state="Success" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
              <ObjectStatus text="Losses: {matches>/summary/losses}" state="Error" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
              <ObjectStatus text="Ties: {matches>/summary/ties}" state="Warning" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
            </HBox>

            <HBox wrap="Wrap" class="sapUiSmallMarginTop">
              <ObjectStatus text="Win rate: {matches>/summary/winRate}" state="Information" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
            </HBox>

            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginTop sapUiTinyMarginBottom">
              <Text text="Loaded: {matches>/paging/loadedCount} / {matches>/paging/totalCount}"/>
            </HBox>

            <Table id="matchesTable" items="{matches>/matches}" busy="{matches>/loading}" growing="true" growingThreshold="20" growingScrollToLoad="true" updateFinished=".onUpdateFinished">
              <headerToolbar>
                <OverflowToolbar>
                  <Title text="Matches history" level="H3"/>
                </OverflowToolbar>
              </headerToolbar>
              <columns>
                <Column><Text text="Match"/></Column>
                <Column><Text text="Opponent"/></Column>
                <Column><Text text="Outcome"/></Column>
                <Column><Text text="Elo Δ"/></Column>
                <Column><Text text="Started"/></Column>
                <Column><Text text="Length"/></Column>
                <Column hAlign="Center"><Text text="Log"/></Column>
                <Column hAlign="Center"><Text text="Replay"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{matches>id}"/>
                    <HBox alignItems="Center" renderType="Bare">
                      <Image src="{matches>opponentRaceIcon}" width="1.5rem" height="1.5rem" decorative="false" densityAware="false" tooltip="{matches>opponentRaceDisplay}" class="sapUiTinyMarginEnd"/>
                      <Text text="{matches>opponent}"/>
                    </HBox>
                    <ObjectStatus text="{matches>outcomeDisplay}" state="{matches>state}"/>
                    <ObjectStatus text="{matches>eloChangeDisplay}" state="{matches>eloChangeState}"/>
                    <ObjectStatus text="{matches>startedDisplay}" state="{matches>startedState}"/>
                    <ObjectStatus text="{matches>gameLength}" state="{matches>gameLengthState}"/>
                    <Button icon="sap-icon://document-text" press=".onOpenLog"/>
                    <Button icon="sap-icon://download" enabled="{= !!${matches>replay} }" press=".onOpenLink">
                      <customData>
                        <core:CustomData key="url" value="{matches>replay}"/>
                      </customData>
                    </Button>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </VBox>
        </content>
      </Page>
    </pages>
  </App>
</mvc:View>
